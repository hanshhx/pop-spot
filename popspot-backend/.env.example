# =================================================================
# POP-SPOT 백엔드 환경변수 템플릿 (.env.example)
# 사용법:
#   1) 이 파일을 복사해 .env 또는 /etc/popspot/popspot.env 로 저장
#   2) 모든 값 채우기 (특히 시크릿)
#   3) systemd EnvironmentFile=/etc/popspot/popspot.env 로 주입
# 절대 .env 자체는 git 에 커밋하지 마세요. (.gitignore 등록 필수)
# =================================================================

# --- 프로필 ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- 도메인 / CORS ---
APP_FRONTEND_URL=https://popspot.co.kr
APP_OAUTH2_REDIRECT_URI=https://popspot.co.kr/oauth/callback
# 쉼표로 여러 개. Vercel preview URL 패턴은 nginx 단에서 차단 권장
APP_ALLOWED_ORIGINS=https://popspot.co.kr,https://popspot.vercel.app
APP_UPLOAD_PATH=/var/popspot/uploads/

# --- Database (PostgreSQL on same VM) ---
DB_URL=jdbc:postgresql://127.0.0.1:5432/popspot_db
DB_USERNAME=popspot_user
DB_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
DB_POOL_MAX=20

# JPA — 운영에서는 validate (스키마 변경은 Flyway 마이그레이션 사용)
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Redis (same VM 또는 GCP Memorystore) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (32바이트 이상! openssl rand -base64 48) ---
JWT_SECRET=__GENERATE_WITH__openssl_rand_-base64_48__MUST_BE_32+_BYTES__
JWT_ACCESS_TOKEN_TTL=3600000

# --- Mail (Gmail 앱 비밀번호 — 2단계 인증 필수) ---
MAIL_USERNAME=your-mail@gmail.com
MAIL_PASSWORD=__GMAIL_APP_PASSWORD__

# --- OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 외부 API 키 ---
SEOUL_API_KEY=
PEXELS_API_KEY=
TMAP_APP_KEY=
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# --- PortOne(아임포트) ---
# 콘솔 > 결제 연동 > 일반결제(REST API) > REST API Key / Secret
IAMPORT_API_KEY=
IAMPORT_API_SECRET=

# --- YouTube Data API v3 (선택) ---
# 미설정 시 팝업 상세에 영상이 표시 안 됨 (서비스는 정상)
# 발급: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# --- Logging / Actuator ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=WARN
ACTUATOR_EXPOSE=health
