# =================================================================
# POP-SPOT 백엔드 환경변수 템플릿 (.env.example)
# 사용법:
#   1) 이 파일을 복사해 .env 또는 /etc/popspot/popspot.env 로 저장
#   2) 모든 값 채우기 (특히 시크릿)
#   3) systemd EnvironmentFile=/etc/popspot/popspot.env 로 주입
# 절대 .env 자체는 git 에 커밋하지 마세요. (.gitignore 등록 필수)
# =================================================================

# --- 프로필 ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- 도메인 / CORS ---
APP_FRONTEND_URL=https://popspot.co.kr
APP_OAUTH2_REDIRECT_URI=https://popspot.co.kr/oauth/callback
# 쉼표로 여러 개. Vercel preview URL 패턴은 nginx 단에서 차단 권장
APP_ALLOWED_ORIGINS=https://popspot.co.kr,https://popspot.vercel.app
APP_UPLOAD_PATH=/var/popspot/uploads/

# --- Database (PostgreSQL on same VM) ---
DB_URL=jdbc:postgresql://127.0.0.1:5432/popspot_db
DB_USERNAME=popspot_user
DB_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
DB_POOL_MAX=20

# JPA — 운영에서는 validate (스키마 변경은 Flyway 마이그레이션 사용)
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Redis (same VM 또는 GCP Memorystore) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (32바이트 이상! openssl rand -base64 48) ---
JWT_SECRET=__GENERATE_WITH__openssl_rand_-base64_48__MUST_BE_32+_BYTES__
JWT_ACCESS_TOKEN_TTL=3600000

# --- Mail (Gmail 앱 비밀번호 — 2단계 인증 필수) ---
MAIL_USERNAME=your-mail@gmail.com
MAIL_PASSWORD=__GMAIL_APP_PASSWORD__

# --- OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 외부 API 키 ---
SEOUL_API_KEY=
PEXELS_API_KEY=
TMAP_APP_KEY=
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
# --- Groq (LLM, OpenAI 호환 API) ---
# 가입: https://console.groq.com → API Keys → Create API Key
# 키 형식: gsk_로 시작하는 문자열
# 무료 한도: 14,400 req/day, 분당 30회
GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- PortOne(아임포트) ---
# 콘솔 > 결제 연동 > 일반결제(REST API) > REST API Key / Secret
IAMPORT_API_KEY=
IAMPORT_API_SECRET=

# --- YouTube Data API v3 (선택) ---
# 미설정 시 팝업 상세에 영상이 표시 안 됨 (서비스는 정상)
# 발급: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# --- Logging / Actuator ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=WARN
ACTUATOR_EXPOSE=health

# --- 팝업스토어 자동수집 (Tier 1: Naver/Kakao Search API + Gemini) ---
# 운영 ON: true / 개발 OFF: false
POPSPOT_CRAWLER_ENABLED=true
# Gemini 신뢰도 ≥ 이 값이면 자동 게시, 그 외 admin 검수 큐
POPSPOT_CRAWLER_CONFIDENCE=0.8
# 자동게시 목표치 — 이만큼 모이면 조기 종료 (0 또는 빈 값 = 무제한)
POPSPOT_CRAWLER_MAX_AUTO_PUBLISHED=10
# Cron 표현식 (KST). 매일 새벽 4시 = "0 0 4 * * *"
POPSPOT_CRAWLER_CRON=0 0 4 * * *
# 권리자 takedown 신고 알림 메일 (운영자 본인 메일 권장)
POPSPOT_TAKEDOWN_NOTIFY_EMAIL=
#
# ⚠️ NAVER_CLIENT_ID/SECRET, KAKAO_REST_API_KEY 는 위 OAuth2 섹션에 이미 있음.
#    검색 API 와 OAuth API 가 같은 키를 공유 (Naver Developer Center / Kakao Developer)
#    발급 가이드: deploy/CRAWLER_API_KEY_GUIDE.md 참조
