# =================================================================
# POP-SPOT 프론트엔드 환경변수 템플릿 (.env.example)
# =================================================================
# 사용:
#   - 로컬 개발: 이 파일을 복사해 .env.local 로 저장 (이미 있다면 수정)
#   - Vercel 배포: 대시보드 > Settings > Environment Variables 에 동일하게 입력
#       (환경별로 Production / Preview / Development 분리 가능)
# =================================================================

# 백엔드 API URL — Compute Engine VM 의 도메인 (https 필수, nginx + Let's Encrypt 통과)
NEXT_PUBLIC_API_URL=https://api.popspot.co.kr

# WebSocket URL — 보통 API 와 동일. 별도 도메인이면 wss://...
NEXT_PUBLIC_SOCKET_URL=https://api.popspot.co.kr

# 카카오 맵 (브라우저 노출되는 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Algolia (검색)
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# 아임포트(PortOne) 가맹점 식별코드 (브라우저 노출 OK)
NEXT_PUBLIC_IAMPORT_MERCHANT_CODE=

# =================================================================
# Vercel 환경변수 등록 시 주의사항
# =================================================================
# 1. NEXT_PUBLIC_ 으로 시작하는 변수만 클라이언트 번들에 노출됨.
# 2. 변경 후에는 반드시 "Redeploy" 해야 적용됨.
# 3. Production / Preview 환경에 동일 변수를 따로 등록할 것.
# 4. 백엔드의 APP_ALLOWED_ORIGINS 에 이 Vercel 도메인이 모두 들어가야 CORS 통과.
