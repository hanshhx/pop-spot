# =================================================================
# POP-SPOT 프론트엔드 환경변수 템플릿 (.env.example)
# =================================================================
# 사용:
#   - 로컬 개발: 이 파일을 복사해 .env.local 로 저장 (이미 있다면 수정)
#   - Vercel 배포: 대시보드 > Settings > Environment Variables 에 동일하게 입력
#       (환경별로 Production / Preview / Development 분리 가능)
# =================================================================

# 백엔드 API URL — https 필수.
#
# ⚠️ 예전 예시였던 api.popspot.co.kr 은 현재 404 다. 운영은 Tailscale Funnel 도메인을 쓴다.
#    실제 값은 Vercel 대시보드 > Settings > Environment Variables 에서 확인할 것.
#    이 값이 비었거나 형식이 틀리면 SEO 랜딩 빌드가 즉시 실패한다(빈 페이지 배포 방지).
NEXT_PUBLIC_API_URL=https://vm-113.tailc57dd4.ts.net

# (비상용, NEXT_PUBLIC_ 아님) SEO 랜딩 빌드의 안전장치를 끄는 탈출구.
#   popups/[slug]/page.tsx 는 백엔드 마커를 3회 재시도 후에도 못 받으면 빌드를 중단한다(빈 SEO 페이지 배포 방지).
#   백엔드 장애 중에도 반드시 배포해야 할 때만 true 로 켠다. 평소엔 절대 설정하지 말 것 —
#   빈 목록 페이지가 색인되면 검색 평판이 깎이고 복구에 수 주가 걸린다.
# ALLOW_EMPTY_SEO_BUILD=true

# WebSocket URL — 보통 API 와 동일. 소켓은 /api/ 밖이라 프록시를 못 타므로 절대 URL 이 필요하다.
NEXT_PUBLIC_SOCKET_URL=https://vm-113.tailc57dd4.ts.net

# 카카오 맵 (브라우저 노출되는 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Algolia (검색)
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# 아임포트(PortOne) 가맹점 식별코드 (브라우저 노출 OK)
NEXT_PUBLIC_IAMPORT_MERCHANT_CODE=

# =================================================================
# Vercel 환경변수 등록 시 주의사항
# =================================================================
# 1. NEXT_PUBLIC_ 으로 시작하는 변수만 클라이언트 번들에 노출됨.
# 2. 변경 후에는 반드시 "Redeploy" 해야 적용됨.
# 3. Production / Preview 환경에 동일 변수를 따로 등록할 것.
# 4. 백엔드의 APP_ALLOWED_ORIGINS 에 이 Vercel 도메인이 모두 들어가야 CORS 통과.
